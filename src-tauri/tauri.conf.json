{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "轻念 · Mindtap",
  "version": "0.1.0",
  "identifier": "com.mindtap.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "轻念 · Mindtap",
        "width": 800,
        "height": 600
      },
      {
        "label": "floating",
        "title": "Mindtap",
        "url": "floating.html",
        "width": 320,
        "height": 36,
        "minWidth": 320,
        "minHeight": 36,
        "maxWidth": 480,
        "maxHeight": 460,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
